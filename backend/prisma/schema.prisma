// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String
  role      String   @default("FARMER")
  location  String?
  verified  Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  listings        Listing[]
  orders         Order[]
  walletTransactions WalletTransaction[]
  trainingCompletions TrainingCompletion[]
  notifications  Notification[]
  buyerReviews   Review[] @relation("ReviewBuyer")
  farmerReviews  Review[] @relation("ReviewFarmer")
  auditLogs      AuditLog[]

  @@map("users")
}

model Listing {
  id          String   @id @default(cuid())
  grade       String   // e.g., "Kangeta", "Alele", "Giza"
  quantity    Int      // in kg
  price       Float    // price per kg in KES
  description String?
  location    String
  farmerId    String
  farmer      User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  orders Order[]

  @@map("listings")
}

model Order {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId     String
  buyer       User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  quantity    Int
  totalPrice  Float
  status      String   @default("PENDING_APPROVAL") // PENDING_APPROVAL, APPROVED, PENDING_PAYMENT, PAID, SHIPPED, DELIVERED, CANCELLED
  deliveryAddress String?
  farmerNotes String?
  paymentMethod String?  // MPESA, CARD, etc.
  mpesaReceiptNumber String?  // M-Pesa transaction receipt
  paidAt      DateTime? // When payment was completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  notifications Notification[]
  review        Review?

  @@map("orders")
}

model Review {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User     @relation("ReviewBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  farmerId  String
  farmer    User     @relation("ReviewFarmer", fields: [farmerId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5 stars
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}

model TrainingModule {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   @default("FARMING_TECHNIQUES")
  content     String   // Full content for the module
  duration    Int      // Duration in minutes
  difficulty  String   @default("BEGINNER")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  completions TrainingCompletion[]

  @@map("training_modules")
}

model TrainingCompletion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId  String
  module    TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, moduleId])
  @@map("training_completions")
}

model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "CREDIT" or "DEBIT"
  amount      Float
  description String
  reference   String?  // M-Pesa transaction ID
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  @@map("wallet_transactions")
}

model Prediction {
  id          String   @id @default(cuid())
  date        DateTime
  grade       String
  actualPrice Float?
  predictedPrice Float
  demandVolume Int
  confidence  Float?  // AI confidence score 0-1
  createdAt   DateTime @default(now())

  @@unique([date, grade])
  @@map("predictions")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // ORDER_RECEIVED, ORDER_APPROVED, ORDER_REJECTED, PAYMENT_RECEIVED, etc.
  title     String
  message   String
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // USER_VERIFIED, LISTING_APPROVED, ORDER_CREATED, etc.
  details   String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

